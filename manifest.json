{
  "manifest_version": 3,
  "name": "Spoiler Tags",
  "version": "0.1.0",
  "description": "Hides text inside <spoiler>...</spoiler> tags in ChatGPT, Claude, and Gemini behind a click-to-reveal cover.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://claude.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
